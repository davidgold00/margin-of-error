# Copy to .env and fill in values. Never commit .env.
# Environment variables override config/model.yaml and config/economics.yaml values.

# Optional: override config file paths
# MOE_ECONOMICS_CONFIG=config/economics.yaml
# MOE_MODEL_CONFIG=config/model.yaml

# Optional: override data paths (useful when data lives outside the repo)
# MOE_KAGGLE_TRAIN_PATH=/path/to/train.csv
# MOE_KAGGLE_TEST_PATH=/path/to/test.csv
# MOE_AMES_FULL_PATH=/path/to/AmesHousing.csv
# MOE_DESCRIPTION_PATH=/path/to/data_description.txt
